# Admin Next.js (:3002). Share DATABASE_URL / OAuth secrets with `frontend/.env` for Prisma auth until APIs move fully to backend.

# Marketing + platform site origin (manager app :3000). Required for links & trip-save form POST from admin.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional explicit marketing URL override (defaults via NEXT_PUBLIC_APP_URL in lib/marketing-site-origin).

# Node API (Sequelize) — all admin trip/event data comes from here (NOT the Next.js host).
# Production test:
# NEXT_PUBLIC_API_URL="https://testapi.busy.mn"
# API_INTERNAL_URL="http://127.0.0.1:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_INTERNAL_URL="http://127.0.0.1:3001"
