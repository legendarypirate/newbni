PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3002

# Optional: comma-separated allowlist (overrides FRONTEND_ORIGIN + ADMIN_ORIGIN when set)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Same DATABASE_URL as busybni (.env)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# Optional explicit vars if not using DATABASE_URL:
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# DB_LOGGING=true
