// PostgreSQL schema for BUSY.mn / BNI (Next.js rewrite). Mirrors legacy MySQL `bni_*` names via @@map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  visitor
  member
  director
  admin
}

enum PlatformAccountStatus {
  active
  suspended
  deleted
}

enum MembershipStatus {
  pending
  active
  expired
  transferred
  left
}

model PlatformAccount {
  id                    BigInt                 @id @default(autoincrement())
  email                 String                 @unique @db.VarChar(255)
  passwordHash          String?                @map("password_hash") @db.VarChar(255)
  passwordResetToken    String?                @map("password_reset_token_hash") @db.Char(64)
  passwordResetExpires  DateTime?              @map("password_reset_expires_at") @db.Timestamptz(6)
  googleSub             String?                @unique @map("google_sub") @db.VarChar(64)
  role                  PlatformRole           @default(visitor)
  status                PlatformAccountStatus  @default(active)
  emailVerifiedAt       DateTime?              @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt           DateTime?              @map("last_login_at") @db.Timestamptz(6)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile     PlatformProfile?
  memberships ChapterMembership[]

  busyRoleAssignments BusyUserRoleAssignment[]
  busyMeetingGroups   BusyMeetingGroup[]      @relation("BusyMeetingGroupOrganizer")
  tripParticipants    TripParticipant[]
  tripFormResponses   TripFormResponse[]

  @@map("bni_platform_accounts")
}

model PlatformProfile {
  accountId     BigInt   @id @map("account_id")
  displayName   String   @default("") @map("display_name") @db.VarChar(255)
  bio           String?  @db.Text
  photoUrl      String?  @map("photo_url") @db.VarChar(512)
  companyName   String?  @map("company_name") @db.VarChar(255)
  businessPhone String?  @map("business_phone") @db.VarChar(64)
  businessEmail String?  @map("business_email") @db.VarChar(255)
  website       String?  @db.VarChar(512)
  addressLine   String?  @map("address_line") @db.VarChar(512)
  businessJson  Json?    @map("business_json")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  account PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("bni_platform_profiles")
}

model Region {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(190)
  slug      String   @unique @db.VarChar(190)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  chapters Chapter[]

  @@map("bni_regions")
}

model Chapter {
  id         Int      @id @default(autoincrement())
  regionId   Int      @map("region_id")
  name       String   @db.VarChar(190)
  slug       String   @db.VarChar(190)
  maxMembers Int      @default(40) @map("max_members")
  timezone   String   @default("Asia/Ulaanbaatar") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  region      Region                  @relation(fields: [regionId], references: [id], onDelete: Restrict)
  events      BniEvent[]
  memberships ChapterMembership[]
  curriculums Curriculum[]
  schedules   ChapterWeeklySchedule[]

  @@unique([regionId, slug])
  @@map("bni_chapters")
}

model ChapterMembership {
  id                 BigInt            @id @default(autoincrement())
  accountId          BigInt            @map("account_id")
  chapterId        Int               @map("chapter_id")
  classificationId Int?              @map("classification_id")
  joinDate         DateTime?         @map("join_date") @db.Date
  expiryDate       DateTime?         @map("expiry_date") @db.Date
  status           MembershipStatus  @default(pending)
  notes            String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  account PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  chapter Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([accountId, chapterId])
  @@map("bni_chapter_memberships")
}

model Curriculum {
  id         Int      @id @default(autoincrement())
  chapterId  Int?     @map("chapter_id")
  name       String   @db.VarChar(190)
  agendaJson Json     @map("agenda_json")
  version    Int      @default(1) @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  chapter   Chapter?                @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  schedules ChapterWeeklySchedule[]
  events    BniEvent[]

  @@map("bni_curriculums")
}

model ChapterWeeklySchedule {
  id           Int      @id @default(autoincrement())
  chapterId    Int      @map("chapter_id")
  curriculumId Int      @map("curriculum_id")
  dayOfWeek    Int      @map("day_of_week") @db.SmallInt
  startTime    DateTime @map("start_time") @db.Time(0)
  endTime      DateTime @map("end_time") @db.Time(0)
  location     String?  @db.VarChar(512)
  isOnline     Boolean  @default(false) @map("is_online")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  chapter    Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Restrict)
  events     BniEvent[]

  @@map("bni_chapter_weekly_schedules")
}

model BniEvent {
  id                      BigInt    @id @default(autoincrement())
  chapterId               Int?      @map("chapter_id")
  scheduleId              Int?      @map("schedule_id")
  // VARCHAR so migrated rows / pgloader mismatch never breaks reads (vs strict Prisma enum).
  eventType               String    @default("weekly_meeting") @map("event_type") @db.VarChar(64)
  startsAt                DateTime  @map("starts_at") @db.Timestamptz(6)
  endsAt                  DateTime  @map("ends_at") @db.Timestamptz(6)
  location                String?   @db.VarChar(512)
  isOnline                Boolean   @default(false) @map("is_online")
  curriculumId            Int?      @map("curriculum_id")
  curriculumOverrideJson  Json?     @map("curriculum_override_json")
  registrationFormJson    Json?     @map("registration_form_json")
  title                   String?   @db.VarChar(255)
  priceMnt                Decimal?  @map("price_mnt") @db.Decimal(12, 2)
  advanceOrderMnt         Decimal?  @map("advance_order_mnt") @db.Decimal(12, 2)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  chapter    Chapter?                @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  schedule   ChapterWeeklySchedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  curriculum Curriculum?             @relation(fields: [curriculumId], references: [id], onDelete: SetNull)

  tripRegistrationForms TripRegistrationForm[]
  tripFormResponses     TripFormResponse[]

  @@index([chapterId, startsAt])
  @@map("bni_events")
}

// --- Legacy public CMS tables (original MySQL schema.sql + migrations; target PostgreSQL via migrate / pgloader) ---

model SiteSetting {
  id           Int       @id @default(autoincrement())
  settingName  String    @unique @map("setting_name") @db.VarChar(100)
  settingValue String?   @map("setting_value") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}

model LegacyMeeting {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  meetingDate     DateTime  @map("meeting_date") @db.Date
  startTime       DateTime  @map("start_time") @db.Time(0)
  endTime         DateTime  @map("end_time") @db.Time(0)
  location        String?   @db.VarChar(255)
  maxAttendees    Int       @default(0) @map("max_attendees")
  description     String?   @db.Text
  status          String    @default("active") @db.VarChar(32)
  bannerImage     String?   @map("banner_image") @db.VarChar(512)
  agendaJson      String?   @map("agenda_json") @db.Text
  priceMnt        Decimal?  @map("price_mnt") @db.Decimal(12, 2)
  advanceOrderMnt Decimal?  @map("advance_order_mnt") @db.Decimal(12, 2)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("meetings")
}

model BusinessTrip {
  id                     Int       @id @default(autoincrement())
  destination            String    @db.VarChar(512)
  startDate              DateTime  @map("start_date") @db.Date
  endDate                DateTime  @map("end_date") @db.Date
  focus                  String?   @db.Text
  description            String?   @db.Text
  statusLabel            String?   @map("status_label") @db.VarChar(255)
  seatsLabel             String?   @map("seats_label") @db.VarChar(255)
  managerAccountId       BigInt?   @map("manager_account_id")
  coverImageUrl          String?   @map("cover_image_url") @db.VarChar(512)
  heroSliderJson         String?   @map("hero_slider_json") @db.Text
  priceMnt               Decimal?  @map("price_mnt") @db.Decimal(12, 2)
  advanceOrderMnt        Decimal?  @map("advance_order_mnt") @db.Decimal(12, 2)
  isFeatured             Int       @default(0) @map("is_featured")
  registrationFormJson   Json?     @map("registration_form_json")
  itineraryJson          Json?     @map("itinerary_json")
  extrasJson             Json?     @map("extras_json")

  tripRegistrationForms TripRegistrationForm[]
  tripFormResponses     TripFormResponse[]
  tripParticipants      TripParticipant[]
  tripPayments          TripPayment[]

  @@map("business_trips")
}

model NewsArticle {
  id          Int       @id @default(autoincrement())
  category    Int?
  type        Int?
  createDate  DateTime? @map("create_date") @db.Date
  title       String    @db.VarChar(512)
  slug        String    @unique @db.VarChar(512)
  excerpt     String?   @db.Text
  content     String?   @db.Text
  body        String?   @db.Text
  image       String?   @db.VarChar(512)
  images      String?   @db.VarChar(512)
  authorId    Int       @map("author_id")
  status      String    @default("draft") @db.VarChar(32)
  featured    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@map("news")
}

model LegacyMember {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  position  String?   @db.VarChar(100)
  company   String?   @db.VarChar(150)
  industry  String?   @db.VarChar(100)
  bio       String?   @db.Text
  email     String?   @db.VarChar(100)
  phone     String?   @db.VarChar(50)
  website   String?   @db.VarChar(255)
  linkedin  String?   @db.VarChar(255)
  facebook  String?   @db.VarChar(255)
  photo     String?   @db.VarChar(255)
  featured  Int       @default(0)
  status    String    @default("active") @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@map("members")
}

model PaymentOrder {
  id                      BigInt    @id @default(autoincrement())
  orderRef                String    @unique @map("order_ref") @db.VarChar(64)
  targetType              String    @map("target_type") @db.VarChar(32)
  targetId                BigInt    @map("target_id")
  fullPriceMnt            Decimal?  @map("full_price_mnt") @db.Decimal(12, 2)
  advancePercent          Int       @default(0) @map("advance_percent") @db.SmallInt
  amountMnt               Int       @map("amount_mnt")
  qpayInvoiceId           String?   @map("qpay_invoice_id") @db.VarChar(128)
  status                  String    @default("pending") @db.VarChar(32)
  qpayInvoiceResponseJson String?   @map("qpay_invoice_response_json") @db.Text
  callbackJson            String?   @map("callback_json") @db.Text
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  paidAt                  DateTime? @map("paid_at") @db.Timestamptz(6)
  baseAdvanceMnt          Int?      @map("base_advance_mnt")
  memberDiscountPercent   Decimal?  @map("member_discount_percent") @db.Decimal(5, 2)

  @@index([targetType, targetId])
  @@map("payment_orders")
}

// =============================================================================
// BUSY.mn modular platform (PostgreSQL). Phase 1: weekly meetings + RBAC.
// Legacy BNI tables above stay on @@map("bni_*"); new modules use busy_*.
// =============================================================================

enum BusyMeetingParticipantType {
  member
  guest
  substitute
}

enum BusyMeetingPaymentStatus {
  unpaid
  paid
  exempted
  refunded
}

enum BusyMeetingAttendanceStatus {
  unknown
  present
  absent
  late
  substitute_present
}

model BusyRole {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(64)
  label       String   @db.VarChar(190)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  permissions BusyRolePermission[]
  assignments BusyUserRoleAssignment[]

  @@map("busy_roles")
}

model BusyPermission {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(128)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles BusyRolePermission[]

  @@map("busy_permissions")
}

model BusyRolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       BusyRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission BusyPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("busy_role_permissions")
}

model BusyUserRoleAssignment {
  id        BigInt   @id @default(autoincrement())
  accountId BigInt   @map("account_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  account PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role    BusyRole        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([accountId, roleId])
  @@index([accountId])
  @@map("busy_user_role_assignments")
}

/// Organizer-facing group (chapter / club / association). Weekly meetings belong to a group.
model BusyMeetingGroup {
  id                 BigInt   @id @default(autoincrement())
  organizerAccountId BigInt   @map("organizer_account_id")
  name               String   @db.VarChar(255)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organizer PlatformAccount    @relation("BusyMeetingGroupOrganizer", fields: [organizerAccountId], references: [id], onDelete: Cascade)
  meetings  BusyWeeklyMeeting[]

  @@index([organizerAccountId])
  @@map("busy_meeting_groups")
}

model BusyWeeklyMeeting {
  id        BigInt @id @default(autoincrement())
  groupId   BigInt @map("group_id")
  /// Opaque token for public QR registration URL (`/m/{token}`).
  publicToken String @unique @map("public_token") @db.VarChar(64)

  meetingDate DateTime @map("meeting_date") @db.Date
  startTime   DateTime @map("start_time") @db.Time(0)
  endTime     DateTime? @map("end_time") @db.Time(0)
  location    String?  @db.VarChar(512)
  feeMnt      Decimal? @map("fee_mnt") @db.Decimal(12, 2)

  enableMemberRegistration    Boolean @default(true) @map("enable_member_registration")
  enableGuestRegistration     Boolean @default(true) @map("enable_guest_registration")
  enableSubstituteRegistration Boolean @default(true) @map("enable_substitute_registration")
  enableShortIntroduction       Boolean @default(true) @map("enable_short_introduction")
  enablePaymentTracking         Boolean @default(true) @map("enable_payment_tracking")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  group          BusyMeetingGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  registrations  BusyMeetingRegistration[]
  rosterExports  BusyMeetingRosterExport[]

  @@index([groupId, meetingDate])
  @@map("busy_weekly_meetings")
}

model BusyMeetingRegistration {
  id              BigInt   @id @default(autoincrement())
  weeklyMeetingId BigInt   @map("weekly_meeting_id")
  participantType BusyMeetingParticipantType @map("participant_type")

  displayName       String  @map("display_name") @db.VarChar(255)
  companyName       String? @map("company_name") @db.VarChar(255)
  position          String? @db.VarChar(255)
  phone             String? @db.VarChar(64)
  email             String? @db.VarChar(255)
  invitedBy         String? @map("invited_by") @db.VarChar(255)
  businessCategory  String? @map("business_category") @db.VarChar(255)
  shortIntroduction String? @map("short_introduction") @db.Text

  paymentStatus    BusyMeetingPaymentStatus    @default(unpaid) @map("payment_status")
  attendanceStatus BusyMeetingAttendanceStatus @default(unknown) @map("attendance_status")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  meeting BusyWeeklyMeeting @relation(fields: [weeklyMeetingId], references: [id], onDelete: Cascade)

  @@index([weeklyMeetingId])
  @@map("busy_meeting_registrations")
}

model BusyMeetingRosterExport {
  id                 BigInt   @id @default(autoincrement())
  weeklyMeetingId    BigInt   @map("weekly_meeting_id")
  format             String   @db.VarChar(32)
  rowCount           Int?     @map("row_count")
  createdByAccountId BigInt?  @map("created_by_account_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  meeting BusyWeeklyMeeting @relation(fields: [weeklyMeetingId], references: [id], onDelete: Cascade)

  @@index([weeklyMeetingId])
  @@map("busy_meeting_roster_exports")
}

model BusyAuditLog {
  id             BigInt   @id @default(autoincrement())
  actorAccountId BigInt?  @map("actor_account_id")
  action         String   @db.VarChar(128)
  subjectType    String   @map("subject_type") @db.VarChar(64)
  subjectId      String   @map("subject_id") @db.VarChar(64)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([subjectType, subjectId])
  @@index([actorAccountId])
  @@map("busy_audit_logs")
}

// --- BUSY.mn trip registration (Google Forms–style builder; MVP) ---

enum TripFormQuestionType {
  SHORT_TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
  CHECKBOXES
  DROPDOWN
  DATE
  TIME
  PHONE
  EMAIL
  FILE_UPLOAD
  NUMBER
  YES_NO
  COUNTRY
  COMPANY_BLOCK
  EMERGENCY_CONTACT_BLOCK
  PAYMENT_CONFIRMATION_BLOCK
}

enum TripFormResponseWorkflowStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CONFIRMED
  CANCELLED
}

enum TripFormMoneyStatus {
  UNPAID
  PENDING
  PAID
  EXEMPTED
  REFUNDED
}

enum TripParticipantLifecycleStatus {
  REGISTERED
  CONFIRMED
  CANCELLED
}

model TripRegistrationForm {
  id          String   @id @default(cuid())
  tripId      Int?     @map("trip_id")
  eventId     BigInt?  @map("event_id")
  title       String   @db.VarChar(512)
  description String?  @db.Text
  publicSlug  String   @unique @map("public_slug") @db.VarChar(160)
  isPublished Boolean  @default(false) @map("is_published")
  settings    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  trip      BusinessTrip? @relation(fields: [tripId], references: [id], onDelete: Cascade)
  event     BniEvent?     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions TripFormQuestion[]
  responses TripFormResponse[]

  @@index([tripId])
  @@index([eventId])
  @@map("trip_registration_forms")
}

model TripFormQuestion {
  id              String               @id @default(cuid())
  formId          String               @map("form_id")
  label           String               @db.VarChar(512)
  description     String?              @db.Text
  type            TripFormQuestionType
  placeholder     String?              @db.VarChar(512)
  isRequired      Boolean              @default(false) @map("is_required")
  sortOrder       Int                  @default(0) @map("sort_order")
  /** True: асуулт одоогийн формын JSON-д байхгүй боловч хуучин хариултад холбогдсон — устгахгүй. */
  retiredFromForm Boolean              @default(false) @map("retired_from_form")
  validationRules Json?               @map("validation_rules")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  form    TripRegistrationForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  options TripFormQuestionOption[]
  answers TripFormResponseAnswer[]

  @@index([formId, sortOrder])
  @@map("trip_form_questions")
}

model TripFormQuestionOption {
  id         String @id @default(cuid())
  questionId String @map("question_id")
  label      String @db.VarChar(512)
  value      String @db.VarChar(512)
  sortOrder  Int    @default(0) @map("sort_order")

  question TripFormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, sortOrder])
  @@map("trip_form_question_options")
}

model TripFormResponse {
  id                String                         @id @default(cuid())
  formId            String                         @map("form_id")
  tripId            Int?                           @map("trip_id")
  eventId           BigInt?                        @map("event_id")
  submittedByUserId BigInt?                        @map("submitted_by_user_id")
  status            TripFormResponseWorkflowStatus @default(SUBMITTED)
  paymentStatus     TripFormMoneyStatus            @default(UNPAID) @map("payment_status")
  /** Trip detail checkout: tier counts, departure, totals (JSON). */
  orderSummary      Json?                          @map("order_summary")
  /** Илгээх үеийн асуулт+хариултын бүрэн хуулбар (форм өөрчлөгдсөн ч харагдана). */
  answersSnapshot   Json?                          @map("answers_snapshot")
  internalNote      String?                        @map("internal_note") @db.Text
  submittedAt       DateTime                       @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt         DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)

  form         TripRegistrationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  trip         BusinessTrip?        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  event        BniEvent?            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submitter    PlatformAccount?     @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)
  answers      TripFormResponseAnswer[]
  participant  TripParticipant?

  @@index([formId])
  @@index([tripId])
  @@index([eventId])
  @@map("trip_form_responses")
}

model TripFormResponseAnswer {
  id         String   @id @default(cuid())
  responseId String @map("response_id")
  questionId String @map("question_id")
  value      String?  @db.Text
  fileUrl    String?  @map("file_url") @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  response TripFormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question TripFormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
  @@map("trip_form_response_answers")
}

model TripParticipant {
  id            String                         @id @default(cuid())
  tripId        Int                            @map("trip_id")
  userId        BigInt?                        @map("user_id")
  responseId    String?                        @unique @map("response_id")
  fullName      String                         @map("full_name") @db.VarChar(255)
  phone         String?                        @db.VarChar(64)
  email         String?                        @db.VarChar(255)
  companyName   String?                        @map("company_name") @db.VarChar(255)
  position      String?                        @db.VarChar(255)
  status        TripParticipantLifecycleStatus @default(REGISTERED)
  paymentStatus TripFormMoneyStatus            @default(UNPAID) @map("payment_status")
  createdAt     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)

  trip     BusinessTrip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  account  PlatformAccount?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  response TripFormResponse? @relation(fields: [responseId], references: [id], onDelete: SetNull)
  payments TripPayment[]

  @@index([tripId])
  @@map("trip_participants")
}

model TripPayment {
  id              String            @id @default(cuid())
  tripId          Int               @map("trip_id")
  participantId   String            @map("participant_id")
  amount          Decimal?          @db.Decimal(12, 2)
  method          String?           @db.VarChar(64)
  status          TripFormMoneyStatus @default(PENDING)
  receiptFileUrl  String?           @map("receipt_file_url") @db.VarChar(512)
  note            String?           @db.Text
  paidAt          DateTime?         @map("paid_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  trip        BusinessTrip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  participant TripParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([participantId])
  @@map("trip_payments")
}
